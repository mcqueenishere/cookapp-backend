# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/cookapp
# Neon:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/cookapp?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/cookapp

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a random 64-char string in production
JWT_SECRET=change-me-to-long-random-string

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
